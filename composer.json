{
    "name": "woocommerce/migrator",
    "description": "A CLI tool to migrate data to WooCommerce.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "WooCommerce",
            "email": "woothemes@woocommerce.com"
        }
    ],
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WooCommerce\\Migrator\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "tests/wp-cli-stubs.php",
            "tests/wp-cli-exit-exception-stub.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "yoast/phpunit-polyfills": "^1.0",
        "woocommerce/woocommerce-sniffs": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require": {
        "php": "^7.4"
    },
    "scripts": {
        "lint": "phpcs",
        "format": "phpcbf",
        "test:setup": "bash bin/install-wp-tests.sh ${DB_NAME:-test_db} ${DB_USER:-root} ${DB_PASS:-''} ${DB_HOST:-localhost}",
        "test": [
            "composer dump-autoload -o",
            "phpunit"
        ]
    }
}
